  "scripts": {
    "start": "npx expo start",
    "start:dc": "npx expo start --dev-client",
    "start:prod": "npx expo start --no-dev --minify",
    "start:android": "npx expo start --android",
    "start:ios": "npx expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "dev:android": "npx expo run:android",
    "build:android": "npx expo run:android --variant release",
    "dev:ios": "npx expo run:ios",
    "build:ios": "npx expo run:ios --configuration Release",
    "dev:ios:d": "npx expo run:ios --device",
    "build:ios:d": "npx expo run:ios --configuration Release --device",
    "web": "expo start --web"
  },
